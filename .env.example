# epic-leek-quant 环境变量模板
# 复制为 .env 后填入实际值。.env 文件已加入 .gitignore。

# =============================================================
# 聚宽平台账号（仅本地调试需要，研究环境无需配置）
# =============================================================
# JOINQUANT_USERNAME=your_phone_or_email
# JOINQUANT_PASSWORD=your_password

# =============================================================
# 数据目录（可选，覆盖脚本内默认路径）
# =============================================================
# RESULTS_DIR=results
